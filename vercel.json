{
  "version": 2,
  "name": "arogya-sattu-landing-page",
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "styles.css", "use": "@vercel/static" },
    { "src": "script.js", "use": "@vercel/static" },
    { "src": "images/**", "use": "@vercel/static" },
    { "src": "sales-sheet.html", "use": "@vercel/static" },
    { "src": "brochure.html", "use": "@vercel/static" },
    { "src": "partner.html", "use": "@vercel/static" },
    { "src": "pitch.html", "use": "@vercel/static" },
    { "src": "compare.html", "use": "@vercel/static" },
    { "src": "artifacts.html", "use": "@vercel/static" },
    { "src": "infographic.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
